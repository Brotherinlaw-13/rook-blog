    function generateEncounter() {
        const partyLevel = document.getElementById('party-level').value;
        const partySize = parseInt(document.getElementById('party-size').value);
        const environment = document.getElementById('environment').value;
        const encounterType = document.getElementById('encounter-type').value;
        const difficulty = document.getElementById('difficulty').value;

        const encounter = {
            monsters: getRandomMonsters(partyLevel, difficulty, partySize),
            environment: encounterData.environments[environment],
            plotHook: getRandomItem(encounterData.plotHooks),
            tactics: getRandomItems(encounterData.tactics[encounterType] || encounterData.tactics['combat'], 3)
        };

        displayEncounter(encounter, encounterType, difficulty);
    }

    function getRandomMonsters(level, difficulty, partySize) {
        const levelData = encounterData.monsters[level] || encounterData.monsters['1-3'];
        const difficultyMonsters = levelData[difficulty] || levelData['easy'];
        
        const groups = [];
        
        if (difficulty === 'deadly') {
            // Boss + some minions
            const boss = getRandomItem(difficultyMonsters);
            groups.push({...boss, count: 1, role: 'Boss'});
            // Add minions from easier tier
            const minions = levelData['easy'] || difficultyMonsters;
            const minionType = getRandomItem(minions);
            const minionCount = Math.floor(Math.random() * partySize) + 2;
            groups.push({...minionType, count: minionCount, role: 'Minion'});
        } else if (difficulty === 'hard') {
            // 1-2 tough monsters + support
            const main = getRandomItem(difficultyMonsters);
            const mainCount = Math.random() > 0.5 ? 2 : 1;
            groups.push({...main, count: mainCount, role: 'Leader'});
            const support = levelData['easy'] || difficultyMonsters;
            const supportType = getRandomItem(support);
            groups.push({...supportType, count: Math.floor(Math.random() * 3) + 2, role: 'Support'});
        } else if (difficulty === 'medium') {
            // A solid group
            const primary = getRandomItem(difficultyMonsters);
            groups.push({...primary, count: Math.floor(Math.random() * 2) + 2, role: 'Primary'});
            if (Math.random() > 0.4) {
                const secondary = getRandomItem(levelData['easy'] || difficultyMonsters);
                groups.push({...secondary, count: Math.floor(Math.random() * 3) + 1, role: 'Secondary'});
            }
        } else {
            // Easy: a straightforward group
            const type = getRandomItem(difficultyMonsters);
            groups.push({...type, count: Math.floor(Math.random() * partySize) + 2, role: 'Standard'});
        }
        
        return groups;
    }

    function getRandomItem(array) {
        return array[Math.floor(Math.random() * array.length)];
    }

    function getRandomItems(array, count) {
        const shuffled = [...array].sort(() => 0.5 - Math.random());
        return shuffled.slice(0, Math.min(count, array.length));
    }

    function displayEncounter(encounter, type, difficulty) {
        const output = document.getElementById('encounter-output');
        const diffLabel = difficulty.charAt(0).toUpperCase() + difficulty.slice(1);
        const typeLabel = type.charAt(0).toUpperCase() + type.slice(1);
        
        let totalMonsters = encounter.monsters.reduce((sum, g) => sum + g.count, 0);
        
        let html = `
            <div class="space-y-5">
                <div class="border-b pb-3">
                    <h3 class="text-xl font-bold text-blue-600">${typeLabel} Encounter</h3>
                    <span class="text-xs font-semibold px-2 py-1 rounded ${
                        difficulty === 'deadly' ? 'bg-red-100 text-red-700' :
                        difficulty === 'hard' ? 'bg-orange-100 text-orange-700' :
                        difficulty === 'medium' ? 'bg-yellow-100 text-yellow-700' :
                        'bg-green-100 text-green-700'
                    }">${diffLabel} · ${totalMonsters} creatures</span>
                </div>
                
                <div>
                    <h4 class="font-bold text-gray-700 mb-2">🎭 Setup</h4>
                    <p class="text-sm text-gray-600 mb-2">${encounter.environment.description}</p>
                    <p class="text-sm text-blue-600 italic">"${encounter.plotHook}"</p>
                </div>

                <div>
                    <h4 class="font-bold text-gray-700 mb-2">👾 Opposition</h4>
                    <ul class="text-sm space-y-2">
        `;

        encounter.monsters.forEach(group => {
            const roleColor = group.role === 'Boss' ? 'text-red-600' : 
                             group.role === 'Leader' ? 'text-orange-600' : 
                             group.role === 'Minion' ? 'text-gray-500' : 'text-gray-700';
            html += `<li class="flex items-center gap-2">
                <span class="text-red-500">⚔️</span>
                <strong>${group.count}x ${group.name}</strong>
                <span class="text-xs ${roleColor}">(CR ${group.cr}, ${group.role})</span>
            </li>`;
        });

        html += `
                    </ul>
                </div>

                <div>
                    <h4 class="font-bold text-gray-700 mb-2">🗺️ Environment Features</h4>
                    <ul class="text-sm space-y-1">
        `;

        encounter.environment.features.forEach(feature => {
            html += `<li class="flex items-center gap-2"><span class="text-green-500">•</span> ${feature}</li>`;
        });

        html += `
                    </ul>
                </div>

                <div>
                    <h4 class="font-bold text-gray-700 mb-2">⚠️ Potential Hazards</h4>
                    <ul class="text-sm space-y-1">
        `;

        encounter.environment.hazards.forEach(hazard => {
            html += `<li class="flex items-center gap-2"><span class="text-yellow-500">•</span> ${hazard}</li>`;
        });

        html += `
                    </ul>
                </div>

                <div>
                    <h4 class="font-bold text-gray-700 mb-2">🎯 Tactical Tips</h4>
                    <ul class="text-sm space-y-2">
        `;

        encounter.tactics.forEach(tactic => {
            html += `<li class="flex items-start gap-2"><span class="text-blue-500 mt-0.5">💡</span> ${tactic}</li>`;
        });

        html += `
                    </ul>
                </div>
            </div>
        `;

        output.innerHTML = html;
    }

    document.getElementById('generate-btn').addEventListener('click', generateEncounter);
    generateEncounter();
</script>
</Layout>
