---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
    title="D&D Encounter Builder"
    description="Generate creative encounters for your D&D sessions"
    pubDate={new Date('2026-02-21')}
    heroImage="/blog-placeholder-2.jpg"
>
    <div class="max-w-4xl mx-auto p-6">
        <h1 class="text-4xl font-bold mb-8 text-center">🐉 D&D Encounter Builder</h1>
        
        <div class="grid md:grid-cols-2 gap-8">
            <!-- Input Panel -->
            <div class="bg-gray-100 p-6 rounded-lg">
                <h2 class="text-2xl font-bold mb-4">Configure Your Encounter</h2>
                
                <div class="space-y-4">
                    <div>
                        <label for="party-level" class="block font-semibold mb-2">Party Level</label>
                        <select id="party-level" class="w-full p-2 border rounded">
                            <option value="1-3">Levels 1-3 (Novice)</option>
                            <option value="4-6">Levels 4-6 (Apprentice)</option>
                            <option value="7-9">Levels 7-9 (Expert)</option>
                            <option value="10-12">Levels 10-12 (Champion)</option>
                            <option value="13-15">Levels 13-15 (Hero)</option>
                            <option value="16-20">Levels 16-20 (Legend)</option>
                        </select>
                    </div>

                    <div>
                        <label for="party-size" class="block font-semibold mb-2">Party Size</label>
                        <select id="party-size" class="w-full p-2 border rounded">
                            <option value="3">3 Players</option>
                            <option value="4" selected>4 Players</option>
                            <option value="5">5 Players</option>
                            <option value="6">6 Players</option>
                        </select>
                    </div>

                    <div>
                        <label for="environment" class="block font-semibold mb-2">Environment</label>
                        <select id="environment" class="w-full p-2 border rounded">
                            <option value="forest">🌲 Forest</option>
                            <option value="dungeon">🏰 Dungeon</option>
                            <option value="city">🏛️ City</option>
                            <option value="wilderness">🏕️ Wilderness</option>
                            <option value="coast">🌊 Coast</option>
                            <option value="mountain">⛰️ Mountain</option>
                            <option value="swamp">🐊 Swamp</option>
                            <option value="desert">🏜️ Desert</option>
                            <option value="underdark">🕳️ Underdark</option>
                            <option value="plane">✨ Other Plane</option>
                        </select>
                    </div>

                    <div>
                        <label for="encounter-type" class="block font-semibold mb-2">Encounter Type</label>
                        <select id="encounter-type" class="w-full p-2 border rounded">
                            <option value="combat">⚔️ Combat</option>
                            <option value="social">🗣️ Social</option>
                            <option value="exploration">🗺️ Exploration</option>
                            <option value="puzzle">🧩 Puzzle</option>
                            <option value="stealth">🥷 Stealth</option>
                            <option value="mixed">🎭 Mixed</option>
                        </select>
                    </div>

                    <div>
                        <label for="difficulty" class="block font-semibold mb-2">Difficulty</label>
                        <select id="difficulty" class="w-full p-2 border rounded">
                            <option value="easy">Easy</option>
                            <option value="medium" selected>Medium</option>
                            <option value="hard">Hard</option>
                            <option value="deadly">Deadly</option>
                        </select>
                    </div>

                    <button id="generate-btn" class="w-full bg-blue-600 text-white py-3 px-6 rounded font-bold hover:bg-blue-700 transition-colors">
                        Generate Encounter ⚡
                    </button>
                </div>
            </div>

            <!-- Output Panel -->
            <div class="bg-white border-2 border-gray-200 p-6 rounded-lg">
                <h2 class="text-2xl font-bold mb-4">Your Encounter</h2>
                <div id="encounter-output" class="text-gray-500 italic">
                    Click "Generate Encounter" to create your adventure!
                </div>
            </div>
        </div>
    </div>
</Layout>

