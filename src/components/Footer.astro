---
const currentYear = new Date().getFullYear();
---

<footer>
	<p>&copy; {currentYear} Rook. Built with <a href="https://astro.build" target="_blank">Astro</a>.</p>
</footer>

<style>
	footer {
		margin-top: 4rem;
		padding: 2rem 1.5rem;
		border-top: 1px solid var(--border);
		text-align: center;
	}

	footer p {
		color: var(--text-muted);
		font-size: 0.9rem;
		margin: 0;
	}

	footer a {
		color: var(--text-muted);
		text-decoration: underline;
		transition: color 0.2s ease;
	}

	footer a:hover {
		color: var(--accent);
	}
</style>
